# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# AI validation
# Optional. If omitted, the pipeline falls back to regex validation.
GROQ_API_KEY=your_groq_api_key_here

# Optional integrations
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here

# Optional proxy
PROXY_SERVER=

# Cookies are stored in .cookies/, not in .env
# See docs/03-extract-cookies.md for setup instructions
